{
  "name": "our-finances-desktop",
  "version": "1.0.0",
  "description": "Our Finances - Shared Sanctuary Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win",
    "build:portable": "electron-builder build --win portable"
  },
  "build": {
    "appId": "com.ourfinances.desktop",
    "productName": "Our Finances",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "../dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../assets/images/icon.png",
      "certificateSubjectName": null,
      "certificateSha1": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2"
  }
}
