{
  "name": "our-finances-desktop",
  "version": "1.2.1",
  "description": "Our Finances - Shared Sanctuary Desktop App",
  "main": "main.js",
  "author": "Shelton Bechani",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shelton-works/Caroline_Sheltonbudgetapp"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win",
    "build:portable": "electron-builder build --win portable",
    "release": "electron-builder build --win --publish always"
  },
  "build": {
    "appId": "com.ourfinances.desktop",
    "productName": "Our Finances",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../assets/images/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github",
      "owner": "Shelton-works",
      "repo": "Caroline_Sheltonbudgetapp",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
