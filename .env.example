# =============================================================================
# Caroline Partner Budget — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Supabase ---
# Get these from your Supabase project dashboard: Settings > API
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# --- API Security ---
# Shared secret the frontend sends as X-SECRET-TOKEN header
BACKEND_SECRET_TOKEN=my-secure-api-key-123

# --- GitHub (auto-updates) ---
# Repository in owner/repo format, e.g. "sheltonbechani/frontend"
GITHUB_REPO=

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for all
CORS_ORIGINS=*

# --- Mock Mode ---
# Set to "true" to use in-memory mock data instead of Supabase
MOCK_MODE=false
